<!--
  Foxy-compatible M20 Pro NavigateToPose tree.
  Keep this tree conservative: Foxy Nav2 does not provide the newer smoother
  and controller plugins used by the old Humble-oriented config.
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="4" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="4" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased" server_timeout="500"/>
            <ReactiveFallback name="PathToPoseFallback">
              <GoalUpdated/>
              <RoundRobin name="GlobalPlannerRecoveryActions">
                <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap" server_timeout="500"/>
                <Wait wait_duration="2" server_timeout="500"/>
              </RoundRobin>
            </ReactiveFallback>
          </RecoveryNode>
        </RateController>
        <!--
          A person can temporarily block every valid DWB trajectory without
          making the navigation goal invalid. Keep the goal alive long enough
          for the scene to clear, and prefer a stationary wait before any
          motion recovery. The bounded retry count still terminates persistent
          obstructions instead of retrying forever.
        -->
        <RecoveryNode number_of_retries="8" name="FollowPath">
          <FollowPath path="{path}" controller_id="FollowPath" server_timeout="500"/>
          <ReactiveFallback name="FollowPathFallback">
            <GoalUpdated/>
            <RoundRobin name="ControllerRecoveryActions">
              <Wait wait_duration="5" server_timeout="500"/>
              <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap" server_timeout="500"/>
              <BackUp backup_dist="0.20" backup_speed="0.07" server_timeout="500"/>
              <Spin spin_dist="0.80" server_timeout="500"/>
            </RoundRobin>
          </ReactiveFallback>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="NavigationRecoveryActions">
          <Wait wait_duration="5" server_timeout="500"/>
          <Sequence name="ClearNavigationCostmaps">
            <ClearEntireCostmap name="ClearLocalCostmap-Navigation" service_name="local_costmap/clear_entirely_local_costmap" server_timeout="500"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Navigation" service_name="global_costmap/clear_entirely_global_costmap" server_timeout="500"/>
          </Sequence>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
