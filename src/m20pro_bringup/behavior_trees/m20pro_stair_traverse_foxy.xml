<!-- Stair-only tree: never clear costmaps, reverse, or spin on steps. -->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <PipelineSequence name="StairTraverseNoMotionRecovery">
      <RateController hz="1.0">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased" server_timeout="500"/>
      </RateController>
      <FollowPath path="{path}" controller_id="FollowPath" server_timeout="500"/>
    </PipelineSequence>
  </BehaviorTree>
</root>
