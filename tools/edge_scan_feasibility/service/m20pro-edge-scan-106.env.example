# Example environment file for a 106-side edge scan service trial.
# Copy to /etc/m20pro-edge-scan-106.env only during an approved service trial.

INPUT_TOPIC=/LIDAR/POINTS
OUTPUT_TOPIC=/m20pro/scan_edge_exp
DURATION_S=0
DOMAIN=0
USE_SHM=0
PREFIX=rt
HEIGHT_MIN=-0.05
HEIGHT_MAX=0.55
MAX_PUBLISH_HZ=4
MAX_POINTS=12000
FRAME_ID=m20pro_base_link
ANGLE_INCREMENT=0.0174533
RANGE_MAX=10.0
RANGE_MIN=0.2
